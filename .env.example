# ZentroPay Full-Stack Configuration
# Copy this file to .env and fill in your values

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASS=password
DB_NAME=zentropay

# ============================================
# REDIS CACHE & SESSION STORE
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispass
REDIS_DB=0

# ============================================
# JWT & AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# PAYMENT GATEWAYS
# ============================================

# Stripe Configuration
STRIPE_SECRET=sk_test_your_stripe_secret_key
STRIPE_PUBLIC=pk_test_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Flutterwave Configuration
FLUTTERWAVE_SECRET=FLWSECK_TEST-your-secret-key
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your-public-key
FLUTTERWAVE_ENCRYPTION_KEY=your-encryption-key

# ============================================
# API CONFIGURATION
# ============================================
API_PORT=3000
API_HOST=localhost
API_CORS_ORIGIN=http://localhost:3001
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=15m

# ============================================
# FRONTEND CONFIGURATION
# ============================================
REACT_APP_API_URL=http://localhost:3000
REACT_APP_ENV=development
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

# ============================================
# EMAIL SERVICE (Nodemailer)
# ============================================
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@zentropay.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ============================================
# AWS/S3 CONFIGURATION
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=zentropay-uploads
AWS_S3_URL=https://zentropay-uploads.s3.amazonaws.com

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
SENTRY_DSN=https://your-sentry-dsn
DATADOG_API_KEY=your-datadog-key

# ============================================
# PGADMIN (Database UI)
# ============================================
PGADMIN_EMAIL=admin@zentropay.local
PGADMIN_PASSWORD=admin

# ============================================
# SECURITY
# ============================================
ENCRYPTION_KEY=your-32-character-encryption-key
SESSION_SECRET=your-session-secret-key
HASH_ROUNDS=10

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_TWO_FACTOR_AUTH=true
FEATURE_WALLET_TRANSFER=true
FEATURE_RECURRING_PAYMENTS=false
FEATURE_MERCHANT_DASHBOARD=true
FEATURE_ADVANCED_ANALYTICS=false

# ============================================
# KUBERNETES & PRODUCTION
# ============================================
KUBERNETES_ENABLED=false
REPLICA_COUNT=1
